// Not used by `docusaurus start/build` — IDE typecheck and `npm run typecheck` only.
{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Docusaurus (IDE typecheck)",
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "module": "esnext",
    "noEmit": true,
    "paths": {
      "@site/*": ["./*"]
    },
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "src/**/*",
    "docusaurus.config.ts",
    "sidebars.ts"
  ],
  "exclude": [".docusaurus", "build"]
}
