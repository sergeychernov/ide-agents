{
  "name": "ide-agents",
  "version": "0.5.0",
  "description": "Local admin for IDE agents and skills from git repos",
  "type": "module",
  "bin": {
    "ide-agents": "./dist/cli.js"
  },
  "files": [
    "dist",
    "template",
    "web/dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:server": "tsc",
    "build:web": "vite build --config web/vite.config.ts",
    "build": "npm run build:server && npm run build:web",
    "prepublishOnly": "npm run build",
    "dev:server": "tsx watch src/cli.ts --no-open",
    "dev:web": "vite --config web/vite.config.ts",
    "dev": "concurrently -n server,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "start": "node dist/cli.js",
    "docs:install": "npm install --prefix docs",
    "docs:start": "npm --prefix docs start",
    "docs:build": "npm --prefix docs run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ide-agents",
    "cursor",
    "skills",
    "agents",
    "subagents",
    "cli",
    "symlink",
    "ide",
    "ai"
  ],
  "author": "sergeychernov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergeychernov/ide-agents.git"
  },
  "homepage": "https://ide-agents.vercel.app/",
  "bugs": {
    "url": "https://github.com/sergeychernov/ide-agents/issues"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "fastify": "^5.8.5",
    "gray-matter": "^4.0.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mantine/core": "^9.2.2",
    "@mantine/hooks": "^9.2.2",
    "@tabler/icons-react": "^3.44.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.3.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14"
  }
}
