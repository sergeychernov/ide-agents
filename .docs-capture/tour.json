{
  "version": 1,
  "baseURL": "http://localhost:5173",
  "server": {
    "command": "npm run dev",
    "cwd": ".",
    "readyUrl": "http://localhost:5173/repositories",
    "readyTimeoutMs": 90000
  },
  "outputDir": "docs/static/img/ui",
  "viewport": { "width": 1440, "height": 900 },
  "pages": [
    {
      "id": "repositories",
      "path": "/repositories",
      "title": "Repositories",
      "fullPage": false,
      "actions": [
        { "waitForSelector": "text=Connected repositories", "timeoutMs": 15000 }
      ]
    },
    {
      "id": "settings",
      "path": "/settings",
      "title": "Settings",
      "fullPage": false,
      "actions": [{ "waitForSelector": "text=What do you use?", "timeoutMs": 15000 }]
    },
    {
      "id": "skills",
      "path": "/repositories",
      "title": "Skills",
      "fullPage": false,
      "actions": [
        { "waitForSelector": "text=Connected repositories", "timeoutMs": 15000 },
        { "waitMs": 800 },
        { "click": "header a[href='/skills']" },
        { "waitForSelector": "h2 >> text=Skills", "timeoutMs": 15000 },
        { "click": "input[aria-haspopup='listbox']" },
        { "waitMs": 300 },
        { "click": "[role='option']:has-text('openai-skills')" },
        { "waitForSelector": "h4:has-text('ASP.NET Core')", "timeoutMs": 30000 }
      ]
    },
    {
      "id": "agents",
      "path": "/repositories",
      "title": "Agents",
      "fullPage": false,
      "actions": [
        { "waitForSelector": "text=Connected repositories", "timeoutMs": 15000 },
        { "waitMs": 800 },
        { "click": "header a[href='/agents']" },
        { "waitForSelector": "h2 >> text=Agents", "timeoutMs": 15000 },
        { "click": "input[aria-haspopup='listbox']" },
        { "waitMs": 300 },
        { "click": "[role='option']:has-text('article-writing-kit')" },
        { "waitForSelector": "h4:has-text('article-architect')", "timeoutMs": 20000 }
      ]
    }
  ]
}
